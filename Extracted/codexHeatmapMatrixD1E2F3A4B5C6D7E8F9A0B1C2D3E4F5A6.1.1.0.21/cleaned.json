    },
    "author": {
        "name": "Nexus Codex",
        "email": "support@nexuscodex.nexus"
    },
    "apiVersion": "5.11.0",
    "style": "style/visual.less",
    "stringResources": {
        "en-US": {
            "Visual_Short_Description": "Colour-coded heatmap grid for two-dimensional data analysis with flexible colour schemes.",
            "Visual_Landing_Message": "Drop Row Category, Column Category, and a Measure to build the heatmap."
        }
    },
    "capabilities": {
        "dataRoles": [
            {
                "displayName": "Row Category",
                "name": "rowCategory",
                "kind": "Grouping",
                "description": "Row axis category (e.g. Beat, Region, Product)"
            },
            {
                "displayName": "Column Category",
                "name": "columnCategory",
                "kind": "Grouping",
                "description": "Column axis category (e.g. Day of Week, Month, Shift)"
            },
            {
                "displayName": "Cell Value",
                "name": "cellValue",
                "kind": "Measure",
                "description": "Numeric value displayed in each cell"
            },
            {
                "displayName": "Sort Order",
                "name": "sortOrder",
                "kind": "Measure",
                "description": "Optional numeric value to control row sort order (ascending)"
            }
        ],
        "dataViewMappings": [
            {
                "conditions": [
                    {
                        "rowCategory": {
                            "max": 1
                        },
                        "columnCategory": {
                            "max": 1
                        },
                        "cellValue": {
                            "max": 1
                        },
                        "sortOrder": {
                            "max": 1
                        }
                    }
                ],
                "categorical": {
                    "categories": {
                        "select": [
                            {
                                "for": {
                                    "in": "rowCategory"
                                }
                            },
                            {
                                "for": {
                                    "in": "columnCategory"
                                }
                            }
                        ],
                        "dataReductionAlgorithm": {
                            "top": {
                                "count": 30000
                            }
                        }
                    },
                    "values": {
                        "select": [
                            {
                                "bind": {
                                    "to": "cellValue"
                                }
                            },
                            {
                                "bind": {
                                    "to": "sortOrder"
                                }
                            }
                        ]
                    }
                }
            }
        ],
