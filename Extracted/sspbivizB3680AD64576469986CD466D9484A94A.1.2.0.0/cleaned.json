{
    "visual": {
        "name": "sspbiviz",
        "displayName": "Smplrspace 3D Viewer",
        "guid": "sspbivizB3680AD64576469986CD466D9484A94A",
        "visualClassName": "Visual",
        "version": "1.2.0.0",
        "description": "Display interactive 3D space models from Smplrspace",
        "supportUrl": "https://www.smplrspace.com/support",
        "gitHubUrl": "https://github.com/smplrspace"
    },
    "author": {
        "name": "Smplrspace",
        "email": "hello@smplrspace.com"
    },
    "apiVersion": "5.11.0",
    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "dataRoles": [
            {
                "displayName": "Data Layer 1",
                "name": "dataLayer1",
                "kind": "GroupingOrMeasure",
                "description": "First data layer: Add columns for spaceId, entityId (required); coordinates, layerType, position (optional). Column names are matched automatically (case-insensitive)."
            },
            {
                "displayName": "Data Layer 2",
                "name": "dataLayer2",
                "kind": "GroupingOrMeasure",
                "description": "Second data layer: Add columns for spaceId, entityId (required); coordinates, layerType, position (optional). Column names are matched automatically (case-insensitive)."
            },
            {
                "displayName": "Data Layer 3",
                "name": "dataLayer3",
                "kind": "GroupingOrMeasure",
                "description": "Third data layer: Add columns for spaceId, entityId (required); coordinates, layerType, position (optional). Column names are matched automatically (case-insensitive)."
            },
            {
                "displayName": "Data Layer 4",
                "name": "dataLayer4",
                "kind": "GroupingOrMeasure",
                "description": "Fourth data layer: Add columns for spaceId, entityId (required); coordinates, layerType, position (optional). Column names are matched automatically (case-insensitive)."
            },
            {
                "displayName": "Data Layer 5",
                "name": "dataLayer5",
                "kind": "GroupingOrMeasure",
                "description": "Fifth data layer: Add columns for spaceId, entityId (required); coordinates, layerType, position (optional). Column names are matched automatically (case-insensitive)."
            },
            {
                "displayName": "Tooltips",
                "name": "tooltips",
                "kind": "GroupingOrMeasure",
                "description": "Fields to display in tooltip when hovering over a polygon (can add multiple fields)"
            },
            {
                "displayName": "Value",
                "name": "value",
                "kind": "Grouping",
                "description": "Numeric or categorical field to determine polygon colors (e.g., capacity, temperature, status)"
            }
        ],
        "objects": {
            "persistedConfig": {
                "properties": {
                    "jsonConfig": {
                        "type": {
                            "text": true
                        }
                    }
                }
            }
        },
        "dataViewMappings": [
            {
                "conditions": [
                    {
                        "dataLayer1": {
                            "min": 0
                        },
                        "dataLayer2": {
                            "min": 0
                        },
                        "dataLayer3": {
                            "min": 0
                        },
                        "dataLayer4": {
                            "min": 0
                        },
                        "dataLayer5": {
                            "min": 0
                        },
                        "tooltips": {
                            "min": 0
                        },
                        "value": {
                            "max": 1
                        }
                    }
                ],
                "categorical": {
                    "categories": {
                        "select": [
                            {
                                "bind": {
                                    "to": "dataLayer1"
                                }
                            },
                            {
                                "bind": {
                                    "to": "dataLayer2"
                                }
                            },
                            {
                                "bind": {
                                    "to": "dataLayer3"
                                }
                            },
                            {
                                "bind": {
                                    "to": "dataLayer4"
                                }
                            },
                            {
                                "bind": {
                                    "to": "dataLayer5"
                                }
                            },
                            {
                                "bind": {
                                    "to": "tooltips"
                                }
                            },
                            {
                                "bind": {
                                    "to": "value"
                                }
                            }
                        ],
                        "dataReductionAlgorithm": {
                            "top": {
                                "count": 10000
                            }
                        }
                    },
                    "values": {
                        "select": []
                    }
                }
            }
        ],
        "supportsHighlight": true,
        "privileges": [
            {
                "name": "WebAccess",
                "essential": true,
                "parameters": [
                    "https://*.smplrspace.com",
                    "https://*.smplrspace.io",
                    "https://firebasestorage.googleapis.com",
                    "https://api.mapbox.com",
                    "https://events.mapbox.com",
                    "https://*.tiles.mapbox.com"
                ]
            }
        ]
    },
    "visualEntryPoint": "",
    "externalJS": [],
    "assets": {
        "icon": "assets/icon.png"
    }
}