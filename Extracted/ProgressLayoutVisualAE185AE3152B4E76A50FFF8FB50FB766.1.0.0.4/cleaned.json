{
    "visual": {
        "name": "ProgressLayout",
        "displayName": "Progress Layout by elwaha.net",
        "guid": "ProgressLayoutVisualAE185AE3152B4E76A50FFF8FB50FB766",
        "visualClassName": "Visual",
        "version": "1.0.0.4",
        "description": "Create {rogress Layout in Power BI",
        "supportUrl": "https://www.elwaha.net/",
        "gitHubUrl": ""
    },
    "author": {
        "name": "Mahmoud Salama",
        "email": "eng.mahmoud3863@outlook.com"
    },
    "apiVersion": "5.10.0",
    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "dataRoles": [
            {
                "displayName": "Villa ID",
                "name": "villaId",
                "kind": "Grouping",
                "description": "Unique identifier for each villa (required)"
            },
            {
                "displayName": "Villa No",
                "name": "villaNo",
                "kind": "Grouping",
                "description": "Display name shown on map"
            },
            {
                "displayName": "X and Y Coordinates",
                "name": "coordinates",
                "kind": "Grouping",
                "description": "Polygon points (format: x,y x,y x,y)"
            },
            {
                "displayName": "Zone",
                "name": "zone",
                "kind": "Grouping",
                "description": "Filter level 1"
            },
            {
                "displayName": "Block",
                "name": "block",
                "kind": "Grouping",
                "description": "Filter level 2"
            },
            {
                "displayName": "Activities",
                "name": "activities",
                "kind": "Measure",
                "description": "Progress values (0 to 1) or text categories"
            }
        ],
        "dataViewMappings": [
            {
                "conditions": [
                    {
                        "villaId": {
                            "max": 1
                        },
                        "villaNo": {
                            "max": 1
                        },
                        "coordinates": {
                            "max": 1
                        },
                        "zone": {
                            "max": 1
                        },
                        "block": {
                            "max": 1
                        },
                        "activities": {
                            "max": 50
                        }
                    }
                ],
                "table": {
                    "rows": {
                        "select": [
                            {
                                "for": {
                                    "in": "villaId"
                                }
                            },
                            {
                                "for": {
                                    "in": "villaNo"
                                }
                            },
                            {
                                "for": {
                                    "in": "coordinates"
                                }
                            },
                            {
                                "for": {
                                    "in": "zone"
                                }
                            },
                            {
                                "for": {
                                    "in": "block"
                                }
                            },
                            {
                                "for": {
                                    "in": "activities"
                                }
                            }
                        ],
                        "dataReductionAlgorithm": {
                            "window": {
                                "count": 30000
                            }
                        }
                    }
                }
            }
        ],
        "objects": {
            "progressColors": {
                "displayName": "Progress Colors",
                "description": "Colors for percentage-based progress values",
                "properties": {
                    "color100": {
