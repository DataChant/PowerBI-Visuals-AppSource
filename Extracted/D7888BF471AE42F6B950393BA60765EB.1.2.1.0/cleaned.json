                    "borderColor": {
                        "displayName": "Border Color",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "borderWidth": {
                        "displayName": "Border Width (px)",
                        "description": "Thickness of result table grid lines in pixels.",
                        "type": {
                            "numeric": true
                        }
                    }
                }
            },
            "defaultFilterSetting": {
                "displayName": "Fallback Filter",
                "description": "Controls the optional fallback filter applied by the visual.",
                "properties": {
                    "DefaultFilter": {
                        "displayName": "Enable Fallback Filter",
                        "description": "Applies the fallback filter value when the visual is cleared or first loads without an active filter.",
                        "type": {
                            "bool": true
                        }
                    },
                    "DefaultFilterValue": {
                        "displayName": "Fallback Filter Value",
                        "description": "Filter value applied automatically when the visual has no typed input.",
                        "type": {
                            "text": true
                        }
                    },
                    "DetectFilter": {
