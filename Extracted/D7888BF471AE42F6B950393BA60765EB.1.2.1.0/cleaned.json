{
    "visual": {
        "name": "lookupVisual",
        "displayName": "Advanced Lookup",
        "guid": "D7888BF471AE42F6B950393BA60765EB",
        "visualClassName": "lookupVisual",
        "version": "1.2.1.0",
        "description": "Paste lookup values, filter across multiple columns, review matched and unmatched keywords in a results table, and apply a fallback filter when no input or active filters are present.",
        "supportUrl": "https://nk225op.com/pbi/pbi-lookup/support.php",
        "gitHubUrl": ""
    },
    "author": {
        "name": "Oplab",
        "email": "support@nk225op.com"
    },
    "apiVersion": "5.10.0",
    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "privileges": [
            {
                "name": "ExportContent",
                "essential": false
            }
        ],
        "dataRoles": [
            {
                "name": "lookupColumn",
                "kind": "Grouping",
                "displayName": "Lookup Column",
                "description": "The column to search/filter against"
            },
            {
                "name": "resultColumns",
                "kind": "GroupingOrMeasure",
                "displayName": "Result Columns",
                "description": "Columns to display in the results table"
            }
        ],
        "dataViewMappings": [
            {
                "conditions": [
                    {
                        "lookupColumn": {
                            "min": 1,
                            "max": 5,
                            "areHierarchicallyRelated": true
                        }
                    }
                ],
                "table": {
                    "rows": {
                        "select": [
                            {
                                "for": {
                                    "in": "lookupColumn"
                                }
                            },
                            {
                                "for": {
                                    "in": "resultColumns"
                                }
                            }
                        ],
                        "dataReductionAlgorithm": {
                            "window": {
                                "count": 30000
                            }
                        }
                    }
                }
            }
        ],
        "objects": {
            "general": {
                "displayName": "General",
                "displayNameKey": "formattingGeneral",
                "properties": {
                    "filter": {
                        "type": {
                            "filter": true
                        }
                    }
                }
            },
            "inputSettings": {
                "displayName": "Input Box",
                "description": "Controls lookup input behavior and button appearance.",
                "properties": {
                    "colDelim": {
                        "displayName": "Column Delimiter",
                        "description": "Optional delimiter to treat as a column separator. It is converted to a tab before filtering.",
                        "type": {
                            "text": true
                        }
                    },
                    "rowDelim": {
                        "displayName": "Row Delimiter",
                        "description": "Optional delimiter to treat as a new lookup row. It is converted to a line break before filtering.",
                        "type": {
                            "text": true
                        }
                    },
                    "background": {
                        "displayName": "Background Color",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "padding": {
                        "displayName": "Padding (px)",
                        "description": "Adds spacing around the input and table inside the visual.",
                        "type": {
                            "numeric": true
                        }
                    },
                    "inputHeight": {
                        "displayName": "Inputbox Size (px)",
                        "description": "Controls the height of the input box in vertical layout, or its width in horizontal layout. Enter 0 for default value.",
                        "type": {
                            "numeric": true
                        }
                    },
                    "inputBorderColor": {
                        "displayName": "Input Border Color",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "inputBackground": {
                        "displayName": "Input Background",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "inputTextColor": {
                        "displayName": "Input Text Color",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "applyButtonColor": {
                        "displayName": "Apply Button Color",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "buttonTextColor": {
                        "displayName": "Button Text Color",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    }
                }
            },
            "tableSettings": {
                "displayName": "Table",
                "description": "Controls table behavior, layout, and display styling.",
                "properties": {
                    "orientation": {
                        "displayName": "Orientation",
                        "description": "Places the input above the results table or beside it.",
                        "type": {
                            "enumeration": [
                                {
                                    "displayName": "Vertical",
                                    "value": "vertical"
                                },
                                {
                                    "displayName": "Horizontal",
                                    "value": "horizontal"
                                }
                            ]
