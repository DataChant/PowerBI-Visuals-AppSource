{
    "visual": {
        "name": "PdfViewerVisual",
        "displayName": "PDF Viewer",
        "guid": "PdfViewerVisual123456789ABCDEF",
        "visualClassName": "Visual",
        "version": "1.0.0.9",
        "description": "A professional PDF viewer with navigation and zoom controls",
        "supportUrl": "https://github.com/abdalla-dabes/pdf-viewer-visual/issues",
        "gitHubUrl": "https://github.com/abdalla-dabes/pdf-viewer-visual"
    },
    "author": {
        "name": "Abdalla Dabes",
        "email": "AbdallaDabes@AbdallaAIsolutions.onmicrosoft.com"
    },
    "apiVersion": "5.10.0",
    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "dataRoles": [
            {
                "displayName": "PDF Files",
                "name": "pdfFiles",
                "kind": "Grouping",
                "description": "Drag PDF file names here for cross-filtering and data-driven PDF viewing"
            }
        ],
        "dataViewMappings": [
            {
                "categorical": {
                    "categories": {
                        "for": {
                            "in": "pdfFiles"
                        },
                        "dataReductionAlgorithm": {
                            "top": {
                                "count": 1000
                            }
                        }
                    }
                }
            }
        ],
        "privileges": [
            {
                "name": "WebAccess",
                "essential": true,
                "parameters": [
                    "https://cdnjs.cloudflare.com",
                    "https://cdn.jsdelivr.net",
                    "https://unpkg.com"
                ]
            }
        ],
        "objects": {
            "pdfData": {
                "displayName": "PDF Storage",
                "properties": {
                    "pdfContent": {
                        "displayName": "PDF Content",
                        "description": "Stores the PDF file data for persistence",
                        "type": {
                            "text": true
                        }
                    },
                    "pdfBackup1": {
                        "displayName": "PDF Backup 1",
                        "description": "First backup location for PDF data",
                        "type": {
                            "text": true
                        }
                    },
                    "pdfBackup2": {
                        "displayName": "PDF Backup 2",
                        "description": "Second backup location for PDF data",
                        "type": {
                            "text": true
                        }
                    },
                    "pdfBackup3": {
                        "displayName": "PDF Backup 3",
                        "description": "Third backup location for PDF data",
                        "type": {
                            "text": true
                        }
                    },
                    "fileName": {
                        "displayName": "File Name",
                        "description": "Name of the stored PDF file",
                        "type": {
                            "text": true
                        }
                    },
                    "uploadTime": {
                        "displayName": "Upload Time",
                        "description": "Timestamp when PDF was uploaded",
                        "type": {
                            "text": true
                        }
                    },
                    "currentPage": {
                        "displayName": "Current Page",
                        "description": "Currently viewed page number",
                        "type": {
                            "numeric": true
                        }
                    },
                    "currentScale": {
                        "displayName": "Current Scale",
                        "description": "Current zoom scale for the PDF",
                        "type": {
                            "numeric": true
                        }
                    },
                    "persistPdf": {
                        "displayName": "Persist PDF",
                        "description": "Enable PDF persistence across page navigation",
                        "type": {
                            "bool": true
                        }
                    },
                    "autoRestore": {
                        "displayName": "Auto Restore",
                        "description": "Automatically restore PDF when visual loads",
                        "type": {
                            "bool": true
                        }
                    }
                }
            },
            "appearance": {
                "displayName": "Appearance",
                "properties": {
                    "backgroundColor": {
                        "displayName": "Background Color",
                        "description": "Visual background color",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "controlColor": {
                        "displayName": "Control Color",
                        "description": "Button and control color theme",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "showToolbar": {
                        "displayName": "Show Toolbar",
                        "description": "Show/hide the main toolbar",
                        "type": {
                            "bool": true
                        }
                    },
                    "toolbarHeight": {
                        "displayName": "Toolbar Height",
                        "description": "Height of the toolbar in pixels",
                        "type": {
                            "numeric": true
                        }
                    },
                    "toolbarBackgroundColor": {
                        "displayName": "Toolbar Background Color",
                        "description": "Background color of the toolbar",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "showDataFieldIndicator": {
                        "displayName": "Show Data Field Indicator",
                        "description": "Show indicator when data field contains files",
                        "type": {
                            "bool": true
                        }
                    }
                }
            },
            "controls": {
                "displayName": "Controls",
                "properties": {
                    "showNavigationButtons": {
                        "displayName": "Show Navigation Buttons",
                        "description": "Show page navigation controls",
                        "type": {
                            "bool": true
                        }
                    },
                    "showZoomControls": {
                        "displayName": "Show Zoom Controls",
                        "description": "Show zoom in/out controls",
                        "type": {
                            "bool": true
                        }
                    },
                    "showFileName": {
                        "displayName": "Show File Name",
                        "description": "Show the PDF file name in the toolbar",
                        "type": {
                            "bool": true
                        }
                    },
                    "showViewerTitle": {
                        "displayName": "Show Viewer Title",
                        "description": "Show 'Enhanced PDF Viewer' title in the toolbar",
                        "type": {
                            "bool": true
                        }
                    }
                }
            },
            "features": {
                "displayName": "Advanced Features",
                "properties": {
                    "showPageNavigator": {
                        "displayName": "Show Page Navigator",
                        "description": "Show page thumbnails navigator on the left side",
                        "type": {
                            "bool": true
                        }
                    },
                    "enableAnnotations": {
                        "displayName": "Enable Annotations",
                        "description": "Allow adding text annotations to PDF pages",
                        "type": {
                            "bool": true
                        }
                    },
                    "pageNavigatorWidth": {
                        "displayName": "Page Navigator Width",
                        "description": "Width of the page navigator panel in pixels",
                        "type": {
                            "numeric": true
                        }
                    },
                    "defaultAnnotationColor": {
                        "displayName": "Default Annotation Color",
                        "description": "Default color for new annotations",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "annotationFontSize": {
                        "displayName": "Annotation Font Size",
                        "description": "Font size for annotation text",
                        "type": {
                            "numeric": true
                        }
                    }
                }
            }
        },
        "supportsHighlight": true,
        "supportsKeyboardFocus": true,
        "supportsSynchronizingFilterState": true,
        "supportsMultiVisualSelection": true,
        "supportsLandingPage": true,
        "supportsEmptyDataView": true
    },
    "visualEntryPoint": "",
    "externalJS": [],
    "assets": {
        "icon": "assets/icon.png"
    }
}