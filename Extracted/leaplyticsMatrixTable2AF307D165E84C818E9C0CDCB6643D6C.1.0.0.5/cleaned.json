{
    "visual": {
        "name": "leaplyticsMatrixTable",
        "displayName": "LeapLytics Matrix Table",
        "guid": "leaplyticsMatrixTable2AF307D165E84C818E9C0CDCB6643D6C",
        "visualClassName": "Visual",
        "version": "1.0.0.5",
        "description": "Matrix table with inline bar charts for financial reporting, P&L statements, variance analysis, and management reporting. Part of the LeapLytics Executive Series.",
        "supportUrl": "https://leaplytics.de/support",
        "gitHubUrl": "https://github.com/spreusler/leaplytics_matrix_table_power_bi"
    },
    "author": {
        "name": "LeapLytics GmbH",
        "email": "support@leaplytics.de"
    },
    "apiVersion": "5.10.0",
    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "privileges": [
            {
                "name": "ExportContent",
                "essential": true
            }
        ],
        "dataRoles": [
            {
                "displayName": "Category",
                "displayNameKey": "Role_Category",
                "name": "category",
                "kind": "Grouping",
                "description": "Row labels for the table (e.g., Product, Region, Account)"
            },
            {
                "displayName": "Value",
                "displayNameKey": "Role_Value",
                "name": "value",
                "kind": "Measure",
                "description": "The measure to display with inline bars"
            },
            {
                "displayName": "Small Multiples",
                "displayNameKey": "Role_SmallMultiples",
                "name": "smallMultiples",
                "kind": "Grouping",
                "description": "Split into columns by this dimension (e.g., Business Unit, Year)"
            },
            {
                "displayName": "PY",
                "displayNameKey": "Role_PreviousYear",
                "name": "previousYear",
                "kind": "Measure",
                "description": "Previous Year values for AC vs PY comparison"
            },
            {
                "displayName": "PL",
                "displayNameKey": "Role_Plan",
                "name": "plan",
                "kind": "Measure",
                "description": "Plan/Budget values for AC vs PL comparison (IBCS - hollow bars)"
            }
        ],
        "dataViewMappings": [
            {
                "conditions": [
                    {
                        "category": {
                            "max": 1
                        },
                        "value": {
                            "max": 1
                        },
                        "smallMultiples": {
                            "max": 1
                        },
                        "previousYear": {
                            "max": 1
                        },
                        "plan": {
                            "max": 1
                        }
                    }
                ],
                "categorical": {
                    "categories": {
                        "select": [
                            {
                                "bind": {
                                    "to": "category"
                                }
                            },
                            {
                                "bind": {
                                    "to": "smallMultiples"
                                }
                            }
                        ],
                        "dataReductionAlgorithm": {
                            "top": {
                                "count": 30000
                            }
                        }
                    },
                    "values": {
                        "select": [
                            {
                                "bind": {
                                    "to": "value"
                                }
                            },
                            {
                                "bind": {
                                    "to": "previousYear"
                                }
                            },
                            {
                                "bind": {
                                    "to": "plan"
                                }
                            }
                        ]
                    }
                }
            }
        ],
        "objects": {
            "license": {
                "displayName": "License",
                "properties": {
                    "license": {
                        "displayName": "License Key",
                        "type": {
                            "text": true
                        }
                    }
                }
            },
            "barSettings": {
                "displayName": "Bar Settings",
                "properties": {
                    "barColor": {
                        "displayName": "Bar Color",
                        "description": "Color for the horizontal bars",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "barPadding": {
                        "displayName": "Bar Spacing",
                        "description": "Space between rows (0-10)",
                        "type": {
                            "numeric": true
                        }
                    }
                }
            },
            "labelSettings": {
                "displayName": "Data Labels",
                "properties": {
                    "showLabels": {
                        "displayName": "Show Data Labels",
                        "description": "Display formatted values next to bars",
                        "type": {
                            "bool": true
                        }
                    },
                    "fontSize": {
                        "displayName": "Font Size",
                        "description": "Font size for value labels (8-24)",
                        "type": {
                            "numeric": true
                        }
                    },
                    "labelColor": {
                        "displayName": "Label Color",
                        "description": "Color for value labels",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    }
                }
            },
            "categorySettings": {
                "displayName": "Category Column",
                "properties": {
                    "fontSize": {
                        "displayName": "Font Size",
                        "description": "Font size for category labels (8-24)",
                        "type": {
                            "numeric": true
                        }
                    },
                    "categoryWidth": {
                        "displayName": "Column Width",
                        "description": "Width of category column in pixels (50-300)",
                        "type": {
                            "numeric": true
                        }
                    }
                }
            },
            "about": {
                "displayName": "About",
                "description": "About This Visual",
                "properties": {
                    "version": {
                        "displayName": "Version",
                        "description": "Visual version",
                        "type": {
                            "text": true
                        }
                    },
                    "developer": {
                        "displayName": "Developed by",
                        "description": "LeapLytics GmbH",
                        "type": {
                            "text": true
                        }
                    }
                }
            }
        },
        "supportsHighlight": true,
        "sorting": {
            "custom": {}
        },
        "suppressDefaultTitle": true,
        "tooltips": {
            "supportedTypes": {
                "default": true,
                "canvas": true
            },
            "supportEnhancedTooltips": true
        },
        "supportsLandingPage": true,
        "supportsEmptyDataView": true
    },
    "visualEntryPoint": "",
    "externalJS": [],
    "assets": {
        "icon": "assets/icon.png"
    }
}