{
    "visual": {
        "name": "ChartMultiplier",
        "displayName": "Chart Multiplier",
        "guid": "ChartMultiplierA94CA601512A416A8FF4906775026B2E",
        "visualClassName": "Visual",
        "version": "1.1.0.2",
        "description": "Small-multiples visual rendering one card per category as a gauge, pie, or bubble chart with optional detail table, color thresholds, cross-filtering, and an overall summary card.",
        "supportUrl": "https://danbistudio.com/visuals/chart-multiplier/docs/",
        "gitHubUrl": ""
    },
    "author": {
        "name": "Daniel Abdel Sater",
        "email": "support@danbistudio.com"
    },
    "apiVersion": "5.11.0",
    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "dataRoles": [
            {
                "displayName": "Category",
                "name": "category",
                "kind": "Grouping",
                "description": "REQUIRED. The outer grouping \u2014 one card per unique value (e.g. project, department). Bound to the matrix rows axis. The Overall card aggregates across all Category values."
            },
            {
                "displayName": "Segment",
                "name": "tableCategory",
                "kind": "Grouping",
                "description": "Optional inner grouping \u2014 breaks each Category card into sub-rows / pie slices / bubbles (e.g. status). Bound to the matrix columns axis so PBI emits per-category \u00d7 per-segment cells AND per-segment grand totals (used by the Overall pie/bubble slice values). Use ISINSCOPE in measures to scope per level."
            },
            {
                "displayName": "Value",
                "name": "value",
                "kind": "Measure",
                "description": "REQUIRED. The primary measure. PBI evaluates this measure at every matrix level: grand total (Overall card), per first-grouping subtotal (category gauge / center number), per leaf (segment row, pie slice, bubble). Use DAX ISINSCOPE in the measure to switch behavior per level \u2014 see USER_GUIDE for the recommended pattern. The data-model format string (currency, percent, etc.) is honored at every render site."
            },
            {
                "displayName": "Min",
                "name": "minValue",
                "kind": "Measure",
                "description": "Gauge scale floor. Optional \u2014 defaults to 0. Used only by the Gauge chart type to anchor the start of the arc. Ignored for Pie and Bubble."
            },
            {
                "displayName": "Max",
                "name": "maxValue",
                "kind": "Measure",
                "description": "Gauge scale ceiling. Optional \u2014 defaults to 100. Used by the Gauge chart type to anchor the end of the arc, and by the 'Show as %' toggle to compute (value / max) \u00d7 100. Ignored for Pie and Bubble (slice / bubble size is determined by Value alone)."
            },
            {
                "displayName": "FX Color",
                "name": "fxColor",
                "kind": "Measure",
                "description": "Optional DAX measure returning a CSS hex color. Like Value, FX Color is evaluated at EVERY matrix level: grand total (Overall card color), per category subtotal (gauge arc color), per leaf (slice / bubble / row color). Use ISINSCOPE in the measure to return different colors per level \u2014 see USER_GUIDE for the recommended pattern. Overrides the Color Mode setting wherever bound."
            },
            {
                "displayName": "Segment Bg fx Color",
                "name": "tableCategoryBgColor",
                "kind": "Measure",
                "description": "Optional DAX measure returning a CSS hex color for the detail-table row background (e.g. '#1e3a5f'). Applies to per-card detail rows and Overall card detail rows (gauge chart type only). Use ISINSCOPE in the measure to scope per level."
            },
            {
                "displayName": "Value Pill fx Color",
                "name": "tableValueBgColor",
                "kind": "Measure",
                "description": "Optional DAX measure returning a CSS hex color for the pill-shaped background behind each row's Segment Value (e.g. '#10b981'). Evaluated per Category \u00d7 Segment. Used only by the Gauge chart type's detail table. Opacity is controlled by Colors \u2192 Pill Bg Opacity."
            },
            {
                "displayName": "Value Text fx Color",
                "name": "tableValueTextColor",
                "kind": "Measure",
                "description": "Optional DAX measure returning a CSS hex color for the Segment Value text (e.g. '#ffffff'). Evaluated per Category \u00d7 Segment. Used only by the Gauge chart type's detail table. When omitted, the visual computes an auto-contrast color from the pill background."
            },
            {
                "displayName": "Tooltips",
                "name": "tooltips",
                "kind": "Measure",
                "description": "Optional measures shown in the tooltip on hover. Bind any number of measures here \u2014 they appear as additional rows below the visual's built-in tooltip content. Applies to all chart types and to both Category cards and Segment rows."
            }
        ],
