    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "dataRoles": [
            {
                "displayName": "Express Id",
                "name": "expressId",
                "kind": "Grouping",
                "description": "Unique identifier from the IFC schema"
            },
            {
                "displayName": "Instanced Mesh Id",
                "name": "instancedMeshId",
                "kind": "Grouping",
                "description": "ID referencing the reusable mesh geometry"
            },
            {
                "displayName": "Geometry Chunks",
                "name": "geometryChunks",
                "kind": "Grouping",
                "description": "Segments of geometry data for rendering"
            },
            {
                "displayName": "Transformation Matrix",
                "name": "transformationMatrix",
                "kind": "Grouping",
                "description": "Matrix defining object position and rotation"
            },
            {
                "displayName": "Hex Color",
                "name": "hexColor",
                "kind": "Grouping",
                "description": "Object color in hexadecimal format"
            },
            {
                "displayName": "Material Opacity",
                "name": "materialOpacity",
                "kind": "Grouping",
                "requiredTypes": [
                    {
                        "numeric": true
                    },
                    {
                        "integer": true
                    }
                ],
                "description": "Transparency level of the object's material"
            }
        ],
        "objects": {
            "dataPoint": {
                "properties": {}
            }
        },
        "dataViewMappings": [
            {
                "categorical": {
                    "categories": {
                        "dataReductionAlgorithm": {
                            "sample": {
                                "count": 30000
                            }
                        },
                        "select": [
                            {
                                "for": {
                                    "in": "expressId"
                                }
                            },
                            {
                                "for": {
                                    "in": "instancedMeshId"
                                }
                            },
                            {
                                "for": {
                                    "in": "geometryChunks"
                                }
                            },
                            {
                                "for": {
                                    "in": "transformationMatrix"
                                }
                            },
                            {
                                "for": {
                                    "in": "hexColor"
                                }
                            },
                            {
                                "for": {
                                    "in": "materialOpacity"
                                }
                            }
                        ]
                    }
                }
            }
        ],
        "privileges": []
    },
