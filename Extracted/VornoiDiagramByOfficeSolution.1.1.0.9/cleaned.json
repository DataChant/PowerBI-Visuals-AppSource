                "properties": {
                    "showToggleChart": {
                        "type": {
                            "bool": true
                        }
                    },
                    "showToggleTheta": {
                        "type": {
                            "bool": true
                        }
                    },
                    "showToggleRadius": {
                        "type": {
                            "bool": true
                        }
                    },
                    "showAllDataPoints": {
                        "type": {
                            "bool": true
                        }
                    },
                    "filter": {
                        "type": {
                            "bool": true
                        }
                    }
                }
            },
            "dataPoint": {
                "properties": {
                    "defaultColor": {
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "showAllDataPoints": {
                        "type": {
                            "bool": true
                        }
                    },
                    "fill": {
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "fillRule": {
                        "type": {
                            "fill": {}
                        }
                    },
                    "fontSize": {
                        "type": {
                            "formatting": {
                                "fontSize": true
                            }
                        }
                    },
                    "radiusSize": {
                        "type": {
                            "formatting": {
                                "fontSize": true
                            }
                        }
                    }
                }
            }
        },
        "dataViewMappings": [
            {
                "categorical": {
                    "categories": {
                        "select": [
                            {
                                "for": {
                                    "in": "x"
                                }
                            },
                            {
                                "for": {
                                    "in": "legend"
                                }
                            }
                        ],
                        "dataReductionAlgorithm": {
                            "top": {}
                        }
                    },
                    "values": {
                        "select": [
                            {
                                "bind": {
                                    "to": "y"
                                }
                            }
                        ]
                    }
                }
            }
        ],
