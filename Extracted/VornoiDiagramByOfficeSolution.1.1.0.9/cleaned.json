    "stringResources": {},
    "capabilities": {
        "dataRoles": [
            {
                "name": "x",
                "kind": "Grouping",
                "displayName": "X Axis"
            },
            {
                "name": "y",
                "kind": "Measure",
                "displayName": "Y Axis"
            },
            {
                "name": "legend",
