{
    "visual": {
        "name": "ImageCarousel",
        "displayName": "Image Carousel",
        "guid": "ImageCarouselByMAQSoftware1448688110701",
        "visualClassName": "Visual",
        "version": "4.1.0.0",
        "description": "A slideshow for cycling through a series of images",
        "supportUrl": "https://bit.ly/maqsoftware-support",
        "gitHubUrl": "https://github.com/MAQ-Software-Solutions/ImageCarousel"
    },
    "author": {
        "name": "MAQ Software",
        "email": "support@maqsoftware.com"
    },
    "apiVersion": "5.11.0",
    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "privileges": [
            {
                "name": "WebAccess",
                "essential": true,
                "parameters": [
                    "https://*"
                ]
            }
        ],
        "dataRoles": [
            {
                "name": "ImageData",
                "displayName": "Image",
                "kind": "Grouping"
            }
        ],
        "supportsLandingPage": true,
        "objects": {
            "carouselProperties": {
                "displayName": "Properties",
                "properties": {
                    "autoNavigationSettings": {
                        "displayName": "Auto slide",
                        "type": {
                            "bool": true
                        }
                    },
                    "zoomOnHover": {
                        "displayName": "Hover to Zoom",
                        "type": {
                            "bool": true
                        }
                    },
                    "viewPortImageCount": {
                        "displayName": "Image count",
                        "type": {
                            "numeric": true
                        }
                    },
                    "slidingSpeed": {
                        "displayName": "Interval",
                        "placeHolderText": "1",
                        "type": {
                            "numeric": true
                        }
                    },
                    "spaceBetweenImages": {
                        "displayName": "Space between images",
                        "type": {
                            "formatting": {
                                "fontSize": true
                            }
                        }
                    },
                    "backgroundColor": {
                        "displayName": "Background color",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    }
                }
            }
        },
        "dataViewMappings": [
            {
                "conditions": [
                    {
                        "ImageData": {
                            "min": 0,
                            "max": 1
                        }
                    }
                ],
                "table": {
                    "rows": {
                        "select": [
                            {
                                "for": {
                                    "in": "ImageData"
                                }
                            }
                        ]
                    }
                }
            }
        ],
        "tooltips": {
            "supportedTypes": {
                "default": true,
                "canvas": true
            },
            "roles": [
                "Tooltips"
            ]
        }
    },
    "visualEntryPoint": "",
    "externalJS": [],
    "assets": {
        "icon": "assets/icon.png"
    }
}