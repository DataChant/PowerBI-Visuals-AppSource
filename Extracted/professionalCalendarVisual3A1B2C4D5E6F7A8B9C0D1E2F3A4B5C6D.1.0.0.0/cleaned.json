        "visualClassName": "Visual",
        "version": "1.0.0.0",
        "description": "Professional Power BI Calendar Visual with Day, Week, Month, and Year views, holiday support, multi-category event bars, and full formatting customization",
        "supportUrl": "mailto:AbdallaDabes@AbdallaAIsolutions.onmicrosoft.com",
        "gitHubUrl": ""
    },
    "author": {
        "name": "Abdalla Dabes, P.E, PSP, PMP",
        "email": "AbdallaDabes@AbdallaAIsolutions.onmicrosoft.com"
    },
    "apiVersion": "5.11.0",
    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "dataRoles": [
            {
                "displayName": "Start Date",
                "name": "startDate",
                "kind": "Grouping",
                "description": "The start date of the calendar range"
            },
            {
                "displayName": "End Date",
                "name": "endDate",
                "kind": "Grouping",
                "description": "The end date of the calendar range"
            },
            {
                "displayName": "Event Title",
                "name": "eventTitle",
                "kind": "Grouping",
                "description": "Title or label for the event/task"
            },
            {
                "displayName": "Event Category",
                "name": "eventCategory",
                "kind": "Grouping",
                "description": "Category or type of event for color-coding"
            },
            {
                "displayName": "Holidays",
                "name": "holidays",
                "kind": "Grouping",
                "description": "Holiday dates to highlight on the calendar"
            },
            {
                "displayName": "Holiday Name",
                "name": "holidayName",
                "kind": "Grouping",
                "description": "Name/label for each holiday"
            },
            {
                "displayName": "Event Value",
                "name": "eventValue",
                "kind": "Measure",
                "description": "Numeric value or metric associated with the event"
            }
        ],
        "dataViewMappings": [
            {
                "conditions": [
                    {
                        "startDate": {
                            "max": 1
                        },
                        "endDate": {
                            "max": 1
                        },
                        "eventTitle": {
                            "max": 1
                        },
                        "eventCategory": {
                            "max": 1
                        },
                        "holidays": {
                            "max": 1
                        },
                        "holidayName": {
                            "max": 1
                        },
                        "eventValue": {
                            "max": 1
                        }
                    }
                ],
                "categorical": {
                    "categories": {
                        "select": [
                            {
                                "for": {
                                    "in": "startDate"
                                }
                            },
                            {
                                "for": {
                                    "in": "endDate"
                                }
                            },
                            {
                                "for": {
                                    "in": "eventTitle"
                                }
                            },
                            {
                                "for": {
                                    "in": "eventCategory"
                                }
                            },
                            {
                                "for": {
                                    "in": "holidays"
                                }
                            },
                            {
                                "for": {
                                    "in": "holidayName"
                                }
                            }
                        ],
                        "dataReductionAlgorithm": {
                            "window": {
                                "count": 10000
                            }
                        }
                    },
                    "values": {
                        "select": [
                            {
                                "for": {
                                    "in": "eventValue"
                                }
                            }
                        ]
                    }
                }
            }
        ],
