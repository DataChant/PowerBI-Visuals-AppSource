{
    "visual": {
        "name": "WriteBackExtreme",
        "displayName": "WriteBackExtreme",
        "guid": "WriteBackExtreme",
        "visualClassName": "WriteBackExtremePBI",
        "version": "6.2.0.2",
        "description": "WriteBackExtreme for PowerBI by AppsForPowerBI",
        "supportUrl": "https://appsforpowerbi.infotopics.com/contact-support",
        "gitHubUrl": ""
    },
    "author": {
        "name": "AppsForPowerBI",
        "email": "info@appsforpowerbi.infotopics.com"
    },
    "apiVersion": "5.11.0",
    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "dataRoles": [
            {
                "displayName": "Primary key",
                "name": "primary_key",
                "kind": "GroupingOrMeasure"
            },
            {
                "displayName": "Default values",
                "name": "default_values",
                "kind": "GroupingOrMeasure"
            },
            {
                "displayName": "Dynamic population",
                "name": "dynamic_population",
                "kind": "GroupingOrMeasure"
            },
            {
                "displayName": "User",
                "name": "username",
                "kind": "GroupingOrMeasure"
            }
        ],
        "objects": {
            "writebackSettings": {
                "properties": {
                    "kv": {
                        "type": {
                            "text": true
                        }
                    },
                    "WBE_URL": {
                        "type": {
                            "text": true
                        }
                    }
                }
            },
            "writebackActions": {
                "properties": {
                    "show": {
                        "type": {
                            "bool": true
                        }
                    }
                }
            }
        },
        "dataViewMappings": [
            {
                "conditions": [
                    {
                        "username": {
                            "max": 1
                        }
                    }
                ],
                "table": {
                    "rows": {
                        "select": [
                            {
                                "for": {
                                    "in": "username"
                                }
                            },
                            {
                                "for": {
                                    "in": "primary_key"
                                }
                            },
                            {
                                "for": {
                                    "in": "default_values"
                                }
                            },
                            {
                                "for": {
                                    "in": "dynamic_population"
                                }
                            }
                        ],
                        "dataReductionAlgorithm": {
                            "window": {
                                "count": 10000
                            }
                        }
                    }
                }
            }
        ],
        "supportsLandingPage": true,
        "supportsEmptyDataView": true,
        "suppressDefaultTitle": true,
        "privileges": [
            {
                "name": "LocalStorage"
            },
            {
                "name": "WebAccess",
                "essential": true,
                "parameters": [
                    "*"
                ]
            },
            {
                "name": "AADAuthentication",
                "parameters": {
                    "COM": "https://appsfortableau.com/writeback-extreme"
                }
            },
            {
                "name": "ExportContent",
                "essential": true
            }
        ]
    },
    "visualEntryPoint": "",
    "externalJS": [],
    "assets": {
        "icon": "assets/icon.png"
    }
}