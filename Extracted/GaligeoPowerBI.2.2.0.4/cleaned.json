{
    "visual": {
        "name": "GaligeoPowerBI",
        "displayName": "Galigeo for PowerBI (2.2.0.4)",
        "guid": "GaligeoPowerBI",
        "visualClassName": "Visual",
        "version": "2.2.0.4",
        "description": "Galigeo for PowerBI",
        "supportUrl": "https://galigeo.com",
        "gitHubUrl": "https://github.com/Galigeo/Galigeo-for-PowerBI"
    },
    "author": {
        "name": "Galigeo",
        "email": "contact@galigeo.com"
    },
    "apiVersion": "5.11.0",
    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "dataRoles": [
            {
                "displayName": "Category Data",
                "name": "category",
                "kind": "Grouping"
            },
            {
                "displayName": "Measure Data",
                "name": "measure",
                "kind": "Measure"
            },
            {
                "name": "longitude",
                "displayName": "Longitude",
                "description": "Coordonn\u00e9e longitude (-180 \u00e0 180)",
                "kind": "Grouping",
                "requiredTypes": [
                    {
                        "numeric": true
                    }
                ],
                "preferredTypes": [
                    {
                        "geography": {
                            "longitude": true
                        }
                    }
                ]
            },
            {
                "name": "latitude",
                "displayName": "Latitude",
                "description": "Coordonn\u00e9e latitude (-90 \u00e0 90)",
                "kind": "Grouping",
                "requiredTypes": [
                    {
                        "numeric": true
                    }
                ],
                "preferredTypes": [
                    {
                        "geography": {
                            "latitude": true
                        }
                    }
                ]
            }
        ],
        "objects": {
            "galigeo": {
                "displayName": "Galigeo Config",
                "properties": {
                    "url": {
                        "displayName": "Galigeo URL",
                        "description": "Specify the url to Galigeo. Ex: https://powerbi.galigeo.com/Galigeo",
                        "type": {
                            "text": true
                        }
                    },
                    "apiKey": {
                        "type": {
                            "text": true
                        }
                    },
                    "mapId": {
                        "type": {
                            "text": true
                        }
                    },
                    "highlight": {
                        "type": {
                            "bool": true
                        }
                    },
                    "infowindow": {
                        "type": {
                            "bool": true
                        }
                    }
                }
            }
        },
        "dataViewMappings": [
            {
                "categorical": {
                    "categories": {
                        "select": [
                            {
                                "for": {
                                    "in": "category"
                                }
                            },
                            {
                                "for": {
                                    "in": "latitude"
                                }
                            },
                            {
                                "for": {
                                    "in": "longitude"
                                }
                            }
                        ],
                        "dataReductionAlgorithm": {
                            "top": {
                                "count": 30000
                            }
                        }
                    },
                    "values": {
                        "select": [
                            {
                                "bind": {
                                    "to": "measure"
                                }
                            },
                            {
                                "bind": {
                                    "to": "latitude"
                                }
                            },
                            {
                                "bind": {
                                    "to": "longitude"
                                }
                            }
                        ]
                    }
                }
            }
        ],
        "supportsHighlight": true,
        "supportsLandingPage": true,
        "supportsEmptyDataView": true,
        "privileges": [
            {
                "name": "WebAccess",
                "essential": true,
                "parameters": [
                    "*"
                ]
            },
            {
                "name": "ExportContent",
                "essential": true
            },
            {
                "name": "AADAuthentication",
                "parameters": {
                    "COM": "https://powerbi.galigeo.com/Galigeo-alpha"
                }
            }
        ]
    },
    "visualEntryPoint": "",
    "externalJS": [],
    "assets": {
        "icon": "assets/icon.png"
    }
}