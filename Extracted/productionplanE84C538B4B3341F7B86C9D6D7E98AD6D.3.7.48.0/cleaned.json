{
    "visual": {
        "name": "productionplan",
        "displayName": "Production Plan",
        "guid": "productionplanE84C538B4B3341F7B86C9D6D7E98AD6D",
        "visualClassName": "Visual",
        "version": "3.7.48.0",
        "description": "v3.7.48 - Resubmission of v3.7.47 with an incremented version number. Includes the Rendering Events API (renderingStarted/Finished/Failed) for Power BI certification. No functional or UI changes; the visual makes no external network calls.",
        "supportUrl": "https://productionvisual.com/support.html",
        "gitHubUrl": "https://productionvisual.com"
    },
    "author": {
        "name": "Production Visual",
        "email": "info@productionvisual.com"
    },
    "apiVersion": "5.10.0",
    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "dataRoles": [
            {
                "name": "productName",
                "displayName": "Product Name",
                "kind": "Grouping",
                "description": "REQUIRED. Product dimension name (e.g. Dim_Product[ProductName]). The products planned and shown."
            },
            {
                "name": "weekNumber",
                "displayName": "Week Number",
                "kind": "Grouping",
                "description": "REQUIRED. Week number (e.g. Dim_Date[WeekNumber] 1..53). Drives current / next / previous week detection and the weekly goal."
            },
            {
                "name": "machineName",
                "displayName": "Machine Name",
                "kind": "Grouping",
                "description": "CONDITIONAL. Bind to Dim_Machine[MachineName] ONLY if your machine dimension is related to every fact you bind (production, goals, deliveries). If not, leave UNBOUND to avoid InvalidUnconstrainedJoin and use a page-level slicer instead."
            },
            {
                "name": "deliveryDate",
                "displayName": "Delivery Date",
                "kind": "Grouping",
                "description": "RECOMMENDED (or manual). RAW day-grain date \u2014 bind the shared Dim_Date[Date]. Do NOT bind WeekStart / MonthStart / aggregated columns (they collapse every delivery to the bucket-start date). Pairs with Delivery Quantity."
            },
            {
                "name": "cycleTime",
                "displayName": "Cycle Time",
                "kind": "Measure",
                "description": "RECOMMENDED. Cycle time per unit (minutes; averaged). Drives machine capacity \u2014 how the schedule sizes each shift. Bind Dim_CycleTime[CycleTime_min] or Fact_Production[CycleTime_min]."
            },
            {
                "name": "pufferQty",
                "displayName": "Puffer Data",
                "kind": "Measure",
                "description": "OPTIONAL. Up to 10 buffer-stock measures (finished-goods, component, raw material, etc.). Each binding adds one buffer chart."
            },
            {
                "name": "producedQty",
                "displayName": "Produced Quantity",
                "kind": "Measure",
                "description": "RECOMMENDED. Produced units (Fact_Production[ProducedQty], summed). Drives completion % and remaining-to-make against Goal."
            },
            {
                "name": "goalQty",
                "displayName": "Goal Quantity",
                "kind": "Measure",
                "description": "RECOMMENDED (or manual). Weekly goal (Fact_WeeklyGoal[GoalQty]). If UNBOUND, enter goals manually in the visual (saved with the report)."
            },
            {
                "name": "deliveryQty",
                "displayName": "Delivery Quantity",
                "kind": "Measure",
                "description": "RECOMMENDED (or manual). Delivery units (Fact_Delivery[DeliveryQty]). Pair with Delivery Date. If UNBOUND, enter deliveries manually in the visual (saved with the report)."
            },
            {
                "name": "productType",
                "displayName": "Product Type",
                "description": "OPTIONAL. Dim_Product[ProductType] (Finished/Component) for explicit classification.",
                "kind": "Grouping"
            },
            {
                "name": "parentProductId",
                "kind": "Grouping",
                "displayName": "BOM Parent Name",
                "description": "OPTIONAL (assemblies only). Parent product NAME \u2014 bind Dim_BOM[ParentProductName]. Explodes finished-goods demand into component demand."
            },
            {
                "name": "componentProductId",
                "kind": "Grouping",
                "displayName": "BOM Component Name",
                "description": "OPTIONAL (assemblies only). Component product NAME \u2014 bind Dim_BOM[ComponentProductName]."
            },
            {
                "name": "qtyPer",
                "kind": "Measure",
                "displayName": "Qty Per Parent",
                "description": "OPTIONAL (assemblies only). Units of this component per one unit of parent (default 1)."
            },
            {
                "name": "typeLevel1",
                "kind": "Grouping",
                "displayName": "Type Level 1",
                "description": "OPTIONAL. Grouping attribute level 1 (e.g. Pinion / Ring / GearSet) \u2014 used by quick-select and parallel-lane grouping."
            },
            {
                "name": "typeLevel2",
                "kind": "Grouping",
                "displayName": "Type Level 2",
                "description": "OPTIONAL. Grouping attribute level 2 \u2014 used by quick-select and parallel-lane grouping."
            },
            {
                "name": "typeLevel3",
                "kind": "Grouping",
                "displayName": "Type Level 3",
                "description": "OPTIONAL. Grouping attribute level 3 \u2014 used by quick-select and parallel-lane grouping."
            }
        ],
