                            {
                                "for": {
                                    "in": "infraId"
                                }
                            },
                            {
                                "for": {
                                    "in": "infraCoordinates"
                                }
                            },
                            {
                                "for": {
                                    "in": "infraNetwork"
                                }
                            },
                            {
                                "for": {
                                    "in": "infraSubNetwork"
                                }
                            },
                            {
                                "for": {
                                    "in": "activityGeoId"
                                }
                            },
                            {
                                "for": {
                                    "in": "activityName"
                                }
                            },
                            {
                                "for": {
                                    "in": "activityValue"
                                }
                            }
