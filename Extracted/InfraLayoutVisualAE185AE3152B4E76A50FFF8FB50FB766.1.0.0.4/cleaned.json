    "capabilities": {
        "dataRoles": [
            {
                "displayName": "Base ID",
                "name": "baseId",
                "kind": "Grouping",
                "description": "Unique ID for each base shape"
            },
            {
                "displayName": "Base Coordinates",
                "name": "baseCoordinates",
                "kind": "Grouping",
                "description": "Polygon points for base layer shapes (format: x,y x,y x,y)"
            },
            {
                "displayName": "Base Label",
                "name": "baseLabel",
                "kind": "Grouping",
                "description": "Optional label shown inside each base shape"
            },
            {
                "displayName": "Base Progress Value",
                "name": "baseProgressValue",
                "kind": "GroupingOrMeasure",
                "description": "Progress 0 to 1 for each base shape. 0 = no fill."
            },
            {
                "displayName": "Infrastructure ID",
                "name": "infraId",
                "kind": "Grouping",
                "description": "Unique ID for each infrastructure geometry"
            },
            {
                "displayName": "Infrastructure Coordinates",
                "name": "infraCoordinates",
                "kind": "Grouping",
                "description": "Linear: X1,Y1 X2,Y2 X3,Y3 ... | Circle: X,Y"
            },
            {
                "displayName": "Infrastructure Network",
                "name": "infraNetwork",
                "kind": "Grouping",
                "description": "Top level network name (Sewage, Storm, Water...)"
            },
            {
                "displayName": "Infrastructure Sub Network",
                "name": "infraSubNetwork",
                "kind": "Grouping",
                "description": "Sub network name (Main Line, Branch A, Manhole...)"
            },
            {
                "displayName": "Activity Geo ID",
                "name": "activityGeoId",
                "kind": "Grouping",
                "description": "Links activity rows to infrastructure geometry ID"
            },
            {
                "displayName": "Activity Name",
                "name": "activityName",
                "kind": "Grouping",
                "description": "Activity name (Excavation, Backfill, Test...)"
            },
            {
                "displayName": "Activity Value",
                "name": "activityValue",
                "kind": "GroupingOrMeasure",
                "description": "Value 0 to 1 or text status"
            }
        ],
        "dataViewMappings": [
            {
                "conditions": [
                    {
                        "baseId": {
                            "max": 1
                        },
                        "baseCoordinates": {
                            "max": 1
                        },
                        "baseLabel": {
