            "Visual_LandingPage_Title": "Image Grid",
            "Visual_LandingPage_Subtitle": "v1.0.0 - LAST UPDATE: FEBRUARY 2026",
            "Visual_LandingPage_DescriptionTitle": "Description",
            "Visual_LandingPage_Description": "Image Grid helps you display a responsive gallery of images in your report with a flexible layout and native Power BI interactions.",
            "Visual_LandingPage_HowToUse": "How to use?",
            "Visual_LandingPage_Step1": "Add an Image URL field to the Image URL bucket. This is the only required field to start displaying your grid.",
            "Visual_LandingPage_Step2": "Add fields to the Title and Subtitle buckets to display labels for each image in the grid.",
            "Visual_LandingPage_Step3": "Use the Format Pane to customize the layout (number of columns, image size) and look (border radius, spacing, colors, and shadows).",
            "Visual_LandingPage_KeyFeatures": "Key Features",
            "Visual_LandingPage_Feature1_Title": "Responsive Layout",
            "Visual_LandingPage_Feature1_Text": "Choose the number of columns and the size of images to adapt the grid to your report layout.",
            "Visual_LandingPage_Feature2_Title": "Interactivity",
            "Visual_LandingPage_Feature2_Text": "Images are selectable. They can open links, show tooltips, use the context menu, and launch drill through.",
            "Visual_LandingPage_Feature3_Title": "Custom Styling",
            "Visual_LandingPage_Feature3_Text": "Detailed styling options for shadows, borders, and typography to match your corporate identity."
