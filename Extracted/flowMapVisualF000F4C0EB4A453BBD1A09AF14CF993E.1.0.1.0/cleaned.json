{
    "visual": {
        "name": "flowMapVisual",
        "displayName": "Flow Map",
        "guid": "flowMapVisualF000F4C0EB4A453BBD1A09AF14CF993E",
        "visualClassName": "Visual",
        "version": "1.0.1.0",
        "description": "Beautiful origin-destination flow map with animated particle arcs, gradient colors, and rich hover tooltips.",
        "supportUrl": "https://github.com/HungMCLe/datayaga-routeflow-map",
        "gitHubUrl": "https://github.com/HungMCLe/datayaga-routeflow-map"
    },
    "author": {
        "name": "Hung Le",
        "email": "hungmcle@gmail.com"
    },
    "apiVersion": "5.10.0",
    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "dataRoles": [
            {
                "displayName": "Route String",
                "name": "rteStrs",
                "kind": "Grouping",
                "description": "Full route string (e.g. 125AL0E62-500E62I60-600I60J10-320J10000) to chain legs into routes"
            },
            {
                "displayName": "Leg Origin Code",
                "name": "legOrigCode",
                "kind": "Grouping",
                "description": "Origin location code for this leg (e.g. AL0, E62)"
            },
            {
                "displayName": "Leg Dest Code",
                "name": "legDestCode",
                "kind": "Grouping",
                "description": "Destination location code for this leg (e.g. E62, I60)"
            },
            {
                "displayName": "Origin Name",
                "name": "originName",
                "kind": "Grouping",
                "description": "Display name for the origin location"
            },
            {
                "displayName": "Destination Name",
                "name": "destName",
                "kind": "Grouping",
                "description": "Display name for the destination location"
            },
            {
                "displayName": "Origin Latitude",
                "name": "originLat",
                "kind": "Measure",
                "description": "Latitude of the origin point"
            },
            {
                "displayName": "Origin Longitude",
                "name": "originLon",
                "kind": "Measure",
                "description": "Longitude of the origin point"
            },
            {
                "displayName": "Destination Latitude",
                "name": "destLat",
                "kind": "Measure",
                "description": "Latitude of the destination point"
            },
            {
                "displayName": "Destination Longitude",
                "name": "destLon",
                "kind": "Measure",
                "description": "Longitude of the destination point"
            },
            {
                "displayName": "Values",
                "name": "values",
                "kind": "Measure",
                "description": "Metric values for the flow (cost, CO2, weight, etc.)"
            }
        ],
        "objects": {
            "mapSettings": {
                "properties": {
                    "mapStyle": {
                        "type": {
                            "enumeration": [
                                {
                                    "value": "dark-v11",
                                    "displayName": "Dark"
                                },
                                {
                                    "value": "light-v11",
                                    "displayName": "Light"
                                },
                                {
                                    "value": "satellite-streets-v12",
                                    "displayName": "Satellite"
                                },
                                {
                                    "value": "navigation-night-v1",
                                    "displayName": "Navigation Dark"
                                },
                                {
                                    "value": "navigation-day-v1",
                                    "displayName": "Navigation Light"
                                }
                            ]
                        }
                    },
                    "mapboxToken": {
                        "type": {
                            "text": true
                        }
                    }
                }
            },
            "flowSettings": {
                "properties": {
                    "arcColor": {
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "arcColorEnd": {
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "arcWidth": {
                        "type": {
                            "numeric": true
                        }
                    },
                    "arcOpacity": {
                        "type": {
                            "numeric": true
                        }
                    },
                    "animationSpeed": {
                        "type": {
                            "numeric": true
                        }
                    },
                    "particleSize": {
                        "type": {
                            "numeric": true
                        }
                    },
                    "showAnimation": {
                        "type": {
                            "bool": true
                        }
                    },
                    "curveHeight": {
                        "type": {
                            "numeric": true
                        }
                    }
                }
            },
            "nodeSettings": {
                "properties": {
                    "showNodes": {
                        "type": {
                            "bool": true
                        }
                    },
                    "nodeColor": {
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "nodeSize": {
                        "type": {
                            "numeric": true
                        }
                    },
                    "showLabels": {
                        "type": {
                            "bool": true
                        }
                    },
                    "labelColor": {
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "labelSize": {
                        "type": {
                            "numeric": true
                        }
                    }
                }
            }
        },
        "dataViewMappings": [
            {
                "categorical": {
                    "categories": {
                        "select": [
                            {
                                "bind": {
                                    "to": "rteStrs"
                                }
                            },
                            {
                                "bind": {
                                    "to": "legOrigCode"
                                }
                            },
                            {
                                "bind": {
                                    "to": "legDestCode"
                                }
                            },
                            {
                                "bind": {
                                    "to": "originName"
                                }
                            },
                            {
                                "bind": {
                                    "to": "destName"
                                }
                            }
                        ],
                        "dataReductionAlgorithm": {
                            "top": {
                                "count": 30000
                            }
                        }
                    },
                    "values": {
                        "select": [
                            {
                                "bind": {
                                    "to": "originLat"
                                }
                            },
                            {
                                "bind": {
                                    "to": "originLon"
                                }
                            },
                            {
                                "bind": {
                                    "to": "destLat"
                                }
                            },
                            {
                                "bind": {
                                    "to": "destLon"
                                }
                            },
                            {
                                "bind": {
                                    "to": "values"
                                }
                            }
                        ]
                    }
                }
            }
        ],
        "privileges": [
            {
                "name": "WebAccess",
                "essential": true,
                "parameters": [
                    "https://*.mapbox.com",
                    "https://*.tiles.mapbox.com"
                ]
            }
        ]
    },
    "visualEntryPoint": "",
    "externalJS": [],
    "assets": {
        "icon": "assets/icon.png"
    }
}