        ],
        "dataViewMappings": [
            {
                "conditions": [
                    {
                        "period": {
                            "max": 1
                        },
                        "plannedPeriodic": {
                            "max": 1
                        },
                        "actualPeriodic": {
                            "max": 1
                        },
                        "cumulativePlanned": {
                            "max": 1
                        },
                        "cumulativeActual": {
                            "max": 1
                        }
