                "categorical": {
                    "categories": {
                        "for": {
                            "in": "period"
                        },
                        "dataReductionAlgorithm": {
                            "top": {
                                "count": 30000
                            }
                        }
                    },
                    "values": {
                        "select": [
                            {
                                "bind": {
                                    "to": "plannedPeriodic"
                                }
                            },
                            {
                                "bind": {
                                    "to": "actualPeriodic"
                                }
                            },
                            {
                                "bind": {
                                    "to": "cumulativePlanned"
                                }
                            },
                            {
                                "bind": {
                                    "to": "cumulativeActual"
                                }
