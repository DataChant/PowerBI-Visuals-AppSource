{
    "visual": {
        "name": "soakFinancialVisual",
        "displayName": "Soak financial visual",
        "guid": "soakFinancialVisual5DCCB1DE9CF948EC944940BA9DF2FDA3",
        "visualClassName": "Visual",
        "version": "1.0.4.11",
        "description": "A Power BI visual for professional financial reporting, providing a structured matrix layout for financial statements, budgeting, and variance analysis.",
        "supportUrl": "https://extentions.soak.dk/documentation-financial-visual-power-bi/",
        "gitHubUrl": ""
    },
    "author": {
        "name": "SOAK A/S",
        "email": "info@soak.dk"
    },
    "apiVersion": "5.10.0",
    "style": "style/visual.less",
    "stringResources": {
        "en-US": {
            "Visual_Short_Description": "Financial reporting visual with hierarchical structure",
            "Visual_Long_Description": "A Power BI visual for professional financial reporting, providing a structured matrix layout for financial statements, budgeting, and variance analysis."
        }
    },
    "capabilities": {
        "dataRoles": [
            {
                "displayName": "No.",
                "name": "nodeId",
                "kind": "Grouping",
                "description": "Unique identifier for each row"
            },
            {
                "displayName": "Parent No.",
                "name": "parentId",
                "kind": "Grouping",
                "description": "Parent identifier for hierarchy"
            },
            {
                "displayName": "Label to show",
                "name": "label",
                "kind": "Grouping",
                "description": "Display label for each row"
            },
            {
                "displayName": "Label to show parents",
                "name": "parentLabel",
                "kind": "Grouping",
                "description": "Display label for parent rows (rows with children). If not provided, uses the regular label."
            },
            {
                "displayName": "Columns",
                "name": "columns",
                "kind": "Grouping",
                "description": "Field to create columns (e.g., Month, Year)"
            },
            {
                "displayName": "Values",
                "name": "values",
                "kind": "Measure",
                "description": "Measure values to display"
            },
            {
                "displayName": "Tooltips",
                "name": "tooltips",
                "kind": "Measure",
                "description": "Measure values to display in tooltip"
            },
            {
                "displayName": "Show Headline",
                "name": "showHeadline",
                "kind": "Grouping",
                "description": "Boolean field (0 or 1) to control whether the group headline/total is shown. Only applies when Move Below Group and Show Title Above Group are enabled."
            },
            {
                "displayName": "Indent from Root",
                "name": "indentFromParent",
                "kind": "Grouping",
                "description": "Numeric field specifying indentation level from root. The indentation will be calculated as: value \u00d7 Indent Size (px). If not provided, hierarchical level-based indentation is used."
            },
            {
                "displayName": "Total Bold",
                "name": "totalBold",
                "kind": "Grouping",
                "description": "Field (0 or 1) to control whether the parent/total row is shown as bold. 0 = normal weight, 1 or not provided = use Totals Bold setting."
            },
            {
                "displayName": "Profit Loss",
                "name": "profitLoss",
                "kind": "Measure",
                "description": "Cumulative P&L measure to transfer to equity. Use a DAX measure that calculates YTD or cumulative result."
            }
        ],
