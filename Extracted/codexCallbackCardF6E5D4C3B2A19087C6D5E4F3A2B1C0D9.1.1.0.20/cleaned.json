                        "lostCount": {
                            "max": 1
                        },
                        "lostRevenue": {
                            "max": 1
                        },
                        "sortOrder": {
                            "max": 1
                        }
                    }
                ],
                "categorical": {
                    "categories": {
                        "for": {
                            "in": "category"
                        },
                        "dataReductionAlgorithm": {
                            "top": {
                                "count": 30000
                            }
                        }
                    },
                    "values": {
                        "select": [
                            {
                                "for": {
                                    "in": "rate"
                                }
                            },
                            {
                                "for": {
                                    "in": "callbackCount"
                                }
                            },
                            {
                                "for": {
                                    "in": "totalCount"
                                }
                            },
                            {
                                "for": {
                                    "in": "lostCount"
                                }
                            },
                            {
                                "for": {
                                    "in": "lostRevenue"
                                }
                            },
                            {
                                "for": {
                                    "in": "sortOrder"
                                }
                            }
                        ]
                    }
                }
            }
        ],
