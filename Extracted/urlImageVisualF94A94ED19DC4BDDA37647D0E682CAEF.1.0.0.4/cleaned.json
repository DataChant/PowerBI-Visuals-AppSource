{
    "visual": {
        "name": "urlImageVisual",
        "displayName": "Dynamic URL Image Visual",
        "guid": "urlImageVisualF94A94ED19DC4BDDA37647D0E682CAEF",
        "visualClassName": "Visual",
        "version": "1.0.0.4",
        "description": "The Dynamic URL Image Visual allows users to display images directly from data-driven URLs. It features customizable scaling (Fit, Fill, Original), alignment controls, and appearance settings like borders, shadows, and rounded corners. Additionally, it supports a dynamic Redirect URL field for interactive drill-through or external navigation.",
        "supportUrl": "https://github.com/anuritinnovation/url-image-md/blob/develop/SUPPORT.md",
        "gitHubUrl": "https://github.com/anuritinnovation/url-image"
    },
    "author": {
        "name": "Sunny Saurav",
        "email": "amrit@anuritinnovation.com"
    },
    "apiVersion": "5.11.0",
    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "dataRoles": [
            {
                "displayName": "Image URL",
                "name": "imageUrl",
                "kind": "Measure"
            },
            {
                "displayName": "Redirect URL",
                "name": "redirectUrl",
                "kind": "Measure"
            }
        ],
        "dataViewMappings": [
            {
                "table": {
                    "rows": {
                        "select": [
                            {
                                "for": {
                                    "in": "imageUrl"
                                }
                            },
                            {
                                "for": {
                                    "in": "redirectUrl"
                                }
                            }
                        ]
                    }
                }
            }
        ],
        "privileges": [
            {
                "name": "WebAccess",
                "essential": true,
                "parameters": [
                    "https://*"
                ]
            }
        ],
        "objects": {
            "imageSettings": {
                "displayName": "Image settings",
                "properties": {
                    "scaling": {
                        "displayName": "Scaling",
                        "type": {
                            "enumeration": [
                                {
                                    "displayName": "Fit",
                                    "value": "fit"
                                },
                                {
                                    "displayName": "Fill",
                                    "value": "fill"
                                },
                                {
                                    "displayName": "Original",
                                    "value": "original"
                                }
                            ]
                        }
                    },
                    "horizontalAlignment": {
                        "displayName": "Horizontal alignment",
                        "type": {
                            "enumeration": [
                                {
                                    "displayName": "Left",
                                    "value": "left"
                                },
                                {
                                    "displayName": "Center",
                                    "value": "center"
                                },
                                {
                                    "displayName": "Right",
                                    "value": "right"
                                }
                            ]
                        }
                    },
                    "verticalAlignment": {
                        "displayName": "Vertical alignment",
                        "type": {
                            "enumeration": [
                                {
                                    "displayName": "Top",
                                    "value": "top"
                                },
                                {
                                    "displayName": "Middle",
                                    "value": "middle"
                                },
                                {
                                    "displayName": "Bottom",
                                    "value": "bottom"
                                }
                            ]
                        }
                    },
                    "width": {
                        "displayName": "Width (px)",
                        "type": {
                            "numeric": true
                        }
                    },
                    "height": {
                        "displayName": "Height (px)",
                        "type": {
                            "numeric": true
                        }
                    }
                }
            },
            "appearance": {
                "displayName": "Appearance",
                "properties": {
                    "showBorder": {
                        "displayName": "Border",
                        "type": {
                            "bool": true
                        }
                    },
                    "borderColor": {
                        "displayName": "Border color",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "borderThickness": {
                        "displayName": "Border thickness",
                        "type": {
                            "numeric": true
                        }
                    },
                    "borderRadius": {
                        "displayName": "Corner radius",
                        "type": {
                            "numeric": true
                        }
                    },
                    "showShadow": {
                        "displayName": "Shadow",
                        "type": {
                            "bool": true
                        }
                    },
                    "shadowColor": {
                        "displayName": "Shadow color",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "padding": {
                        "displayName": "Padding",
                        "type": {
                            "numeric": true
                        }
                    }
                }
