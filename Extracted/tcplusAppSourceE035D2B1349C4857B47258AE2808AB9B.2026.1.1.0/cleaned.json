        "gitHubUrl": "https://github.com/HighCoordination/tc-plus-appsource"
    },
    "author": {
        "name": "TRUECHART P/L",
        "email": "info@highcoordination.com"
    },
    "apiVersion": "5.11.0",
    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "suppressDefaultTitle": true,
        "dataRoles": [
            {
                "displayName": "Dimensions",
                "name": "category",
                "kind": "Grouping"
            },
            {
                "displayName": "Measures",
                "name": "measure",
                "kind": "Measure"
            }
        ],
        "dataViewMappings": [
            {
                "conditions": [
                    {
                        "category": {
                            "min": 0,
                            "max": 20
                        },
                        "measure": {
                            "min": 0
                        }
                    }
                ],
                "table": {
                    "rows": {
                        "select": [
                            {
                                "for": {
                                    "in": "category"
                                }
                            },
                            {
                                "for": {
                                    "in": "measure"
                                }
                            }
                        ],
                        "dataReductionAlgorithm": {
                            "top": {
                                "count": 30000
                            }
                        }
                    }
                }
            }
        ],
        "objects": {
            "chart": {
                "properties": {
                    "chartType": {
                        "type": {
                            "numeric": true
                        }
                    },
                    "library": {
                        "type": {
                            "numeric": true
                        }
                    }
                }
            },
            "internal": {
                "properties": {
                    "saveObject": {
                        "type": {
                            "text": true
                        }
                    },
                    "lastEditModeAt": {
                        "type": {
                            "text": true
                        }
                    }
                }
            }
        },
        "tooltips": {
            "supportedTypes": {
                "default": true,
                "canvas": true
            },
            "roles": [
                "Tooltips"
            ]
        },
        "supportsHighlight": false,
        "supportsLandingPage": true,
        "supportsMultiVisualSelection": true,
        "privileges": [
            {
                "name": "LocalStorage",
                "essential": true
            }
        ],
        "sorting": {
            "implicit": {
                "clauses": [
                    {
                        "role": "category",
                        "direction": 1
                    },
                    {
                        "role": "measure",
                        "direction": 1
                    }
                ]
            }
        }
    },
    "visualEntryPoint": "",
    "externalJS": [],
    "assets": {
        "icon": "assets/icon.png"
    }
