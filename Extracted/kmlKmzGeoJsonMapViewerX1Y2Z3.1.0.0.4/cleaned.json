    "capabilities": {
        "dataRoles": [
            {
                "name": "geoUrl",
                "displayName": "KML/KMZ URL (Optional)",
                "displayNameKey": "Visual_GeoUrl",
                "kind": "GroupingOrMeasure",
                "description": "Optional: URL or path to KML/KMZ file"
            },
            {
                "name": "layers",
                "displayName": "Layers (Filter)",
                "displayNameKey": "Visual_Layers",
                "kind": "Grouping",
                "description": "Filter layers by name/category"
            },
            {
                "name": "tooltips",
                "displayName": "Tooltips",
                "displayNameKey": "Visual_Tooltips",
                "kind": "GroupingOrMeasure",
                "description": "Fields shown in the tooltip when hovering over a feature"
            },
            {
                "name": "measure",
                "displayName": "Measure",
                "displayNameKey": "Visual_Measure",
                "kind": "Measure",
                "description": "Numeric measure associated with each layer/feature"
            }
        ],
        "dataViewMappings": [
            {
                "categorical": {
                    "categories": {
                        "for": {
                            "in": "layers"
                        },
                        "dataReductionAlgorithm": {
                            "top": {
                                "count": 1000
                            }
                        }
                    },
                    "values": {
                        "select": [
                            {
                                "bind": {
                                    "to": "measure"
                                }
                            },
                            {
                                "for": {
                                    "in": "tooltips"
                                }
                            }
                        ]
                    }
                }
            }
        ],
