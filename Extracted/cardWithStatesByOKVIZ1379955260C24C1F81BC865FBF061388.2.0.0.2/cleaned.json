                    }
                ],
                "categorical": {
                    "categories": {
                        "select": [
                            {
                                "for": {
                                    "in": "category"
                                }
                            },
                            {
                                "for": {
                                    "in": "axis"
                                }
                            }
                        ],
                        "dataReductionAlgorithm": {
                            "top": {
                                "count": 30000
                            }
                        }
                    },
                    "values": {
                        "select": [
                            {
                                "bind": {
                                    "to": "Values"
                                }
                            },
                            {
                                "bind": {
                                    "to": "target"
                                }
                            },
                            {
                                "bind": {
                                    "to": "colorRules"
                                }
                            },
                            {
                                "bind": {
                                    "to": "tooltips"
                                }
                            }
                        ],
                        "dataReductionAlgorithm": {
                            "top": {
                                "count": 30000
                            }
                        }
                    }
                }
            }
        ],
