    "visual": {
        "name": "cardWithStatesByOKVIZ",
        "displayName": "Card with States by OKVIZ",
        "guid": "cardWithStatesByOKVIZ1379955260C24C1F81BC865FBF061388",
        "visualClassName": "Visual",
        "version": "2.0.0.2",
        "description": "Card with States by OKVIZ lets you display a performance measure with conditional states that drive the card appearance, plus optional targets and trendlines, with full control over formatting.",
        "supportUrl": "https://okviz.com/card-with-states/",
        "gitHubUrl": ""
    },
    "author": {
        "name": "OKVIZ",
        "email": "support@okviz.com"
    },
    "apiVersion": "5.11.0",
    "style": "style/visual.less",
    "stringResources": {
        "en-US": {},
        "fr-FR": {},
        "hi-IN": {},
        "it-IT": {}
    },
    "capabilities": {
        "dataRoles": [
            {
                "displayName": "Values (?)",
                "description": "(Required) Set the measure(s) to display. You can bind multiple measures in order to display multiple cards. In this case, the 'Category' field well will be disabled.",
                "name": "Values",
                "kind": "Measure"
            },
            {
                "displayName": "Category (?)",
                "description": "Set the column to define multiple cards. If you set a column here, 'Measures' and 'Targets' will accept a single measure each.",
                "name": "category",
                "kind": "Grouping"
            },
            {
                "displayName": "Targets (?)",
                "description": "Set the target(s) of the card(s). This measure is used to calculate the card change and is considered the last condition to assign states. If you don't set it, the reference label is not available. If the 'Category' is empty, you can bind multiple measures here. In this case, you have to bind the same number of measures as in the 'Values' section.",
                "name": "target",
                "kind": "Measure"
            },
            {
                "displayName": "Color Rules (?)",
                "description": "Use this field well to set conditional formatting rules for the card(s).",
                "name": "colorRules",
                "kind": "Measure"
            },
            {
                "displayName": "Trendline axis (?)",
                "description": "Set a column to be displayed as a trendline.",
                "name": "axis",
                "kind": "GroupingOrMeasure"
            },
            {
                "displayName": "Tooltips (?)",
                "description": "Set additional measures to be included in the card tooltips.",
                "name": "tooltips",
                "kind": "Measure"
            }
        ],
        "dataViewMappings": [
            {
                "conditions": [
                    {
                        "Values": {
                            "max": 1,
                            "min": 1
                        },
                        "target": {
                            "max": 1
                        },
