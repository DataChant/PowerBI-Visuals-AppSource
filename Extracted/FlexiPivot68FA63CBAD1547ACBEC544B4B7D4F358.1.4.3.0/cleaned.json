{
    "visual": {
        "name": "FlexiPivot",
        "displayName": "FlexiPivot",
        "guid": "FlexiPivot68FA63CBAD1547ACBEC544B4B7D4F358",
        "visualClassName": "Visual",
        "version": "1.4.3.0",
        "description": "Interactive Pivot Table for Power BI with drag-and-drop functionality",
        "supportUrl": "https://precisionbisolutions.com/flexipivot",
        "gitHubUrl": ""
    },
    "author": {
        "name": "Precision BI Solutions",
        "email": "info@precisionbisolutions.com"
    },
    "apiVersion": "5.10.0",
    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "dataRoles": [
            {
                "name": "Field",
                "kind": "Grouping",
                "displayName": "Filters",
                "description": "Fields to use in the pivot table"
            },
            {
                "name": "Value",
                "kind": "Measure",
                "displayName": "Values",
                "description": "Fields to aggregate"
            },
            {
                "name": "Tooltips",
                "kind": "Measure",
                "displayName": "Tooltips",
                "description": "Additional fields to show in tooltips"
            }
        ],
        "dataViewMappings": [
            {
                "conditions": [
                    {
                        "Field": {
                            "max": 10
                        },
                        "Value": {
                            "max": 10
                        },
                        "Tooltips": {
                            "max": 10
                        }
                    }
                ],
                "matrix": {
                    "rows": {
                        "for": {
                            "in": "Field"
                        },
                        "dataReductionAlgorithm": {
                            "window": {
                                "count": 100000
                            }
                        }
                    },
                    "values": {
                        "select": [
                            {
                                "for": {
                                    "in": "Value"
                                }
                            },
                            {
                                "for": {
                                    "in": "Tooltips"
                                }
                            }
                        ]
                    }
                }
            }
        ],
        "objects": {
            "chartSettings": {
                "displayName": "Chart Settings",
                "properties": {
                    "chartTitle": {
                        "displayName": "Chart Title",
                        "description": "Static text for chart title (overrides auto-generated title)",
                        "type": {
