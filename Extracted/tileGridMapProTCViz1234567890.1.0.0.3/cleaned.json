{
    "visual": {
        "name": "tileGridMapPro",
        "displayName": "Tile Grid Map Pro",
        "guid": "tileGridMapProTCViz1234567890",
        "visualClassName": "Visual",
        "version": "1.0.0.3",
        "description": "Visualize geographic data as interactive tile grids. Supports 27 countries and regions with precise boundaries. Free tier includes 500 data points. Upgrade to Pro for unlimited data and custom color scales.",
        "supportUrl": "https://tinocallarisa-web.github.io/tile-grid-map-pro/support.html",
        "gitHubUrl": "https://github.com/tinocallarisa-web/tile-grid-map-pro"
    },
    "author": {
        "name": "TCViz",
        "email": "tino@tcviz.com"
    },
    "apiVersion": "5.10.0",
    "style": "style/visual.less",
    "stringResources": {
        "en-US": {
            "visual_displayName": "Tile Grid Map Pro",
            "visual_description": "Ship geo dashboards without a custom tile server. Bundled admin boundaries for 90+ countries rendered as square or hexagon tile grids.",
            "mapSettings_displayName": "Map Settings",
            "mapSettings_country_displayName": "Country / Region",
            "mapSettings_tileShape_displayName": "Tile Shape",
            "mapSettings_showLabels_displayName": "Show Labels",
            "mapSettings_labelFontSize_displayName": "Label Font Size",
            "colorScale_displayName": "Color Scale",
            "colorScale_scaleType_displayName": "Scale Type",
            "colorScale_colorMin_displayName": "Color Min",
            "colorScale_colorMid_displayName": "Color Mid (Diverging)",
            "colorScale_colorMax_displayName": "Color Max",
            "colorScale_noDataColor_displayName": "No Data Color",
            "bubbleOverlay_displayName": "Bubble Overlay (Pro)",
            "bubbleOverlay_showBubbles_displayName": "Show Bubbles",
            "bubbleOverlay_bubbleColor_displayName": "Bubble Color",
            "bubbleOverlay_bubbleOpacity_displayName": "Bubble Opacity (%)",
            "bubbleOverlay_maxBubbleSize_displayName": "Max Bubble Size (px)",
            "legend_displayName": "Legend",
            "legend_showLegend_displayName": "Show Legend",
            "legend_legendPosition_displayName": "Position",
            "proSettings_displayName": "Pro Settings",
            "proSettings_customTopoJsonUrl_displayName": "Custom TopoJSON URL",
            "proSettings_showPill_displayName": "Show Pro Pill"
        }
    },
    "capabilities": {
        "dataRoles": [
            {
                "name": "latitude",
                "kind": "Grouping",
                "displayName": "Latitude",
                "description": "Latitude column (decimal degrees, e.g. 40.4168)"
            },
            {
                "name": "longitude",
                "kind": "Grouping",
                "displayName": "Longitude",
                "description": "Longitude column (decimal degrees, e.g. -3.7038)"
            },
            {
                "name": "value",
                "kind": "Measure",
                "displayName": "Value",
                "description": "Numeric value to color each tile"
            },
            {
                "name": "tooltips",
                "kind": "Measure",
                "displayName": "Tooltips",
                "description": "Additional fields shown in tooltip"
            },
            {
                "name": "label",
                "kind": "Grouping",
                "displayName": "Label",
                "description": "Optional display name (city, region...)"
            }
        ],
        "dataViewMappings": [
            {
                "conditions": [
                    {
                        "latitude": {
                            "max": 1
                        },
                        "longitude": {
                            "max": 1
                        },
                        "value": {
                            "max": 1
                        },
                        "tooltips": {
                            "max": 10
                        },
                        "label": {
                            "max": 1
                        }
                    }
                ],
                "table": {
                    "rows": {
                        "select": [
                            {
                                "for": {
                                    "in": "latitude"
                                }
                            },
                            {
                                "for": {
                                    "in": "longitude"
                                }
                            },
                            {
                                "for": {
                                    "in": "label"
                                }
                            },
                            {
                                "bind": {
                                    "to": "value"
                                }
                            },
                            {
                                "bind": {
                                    "to": "tooltips"
                                }
                            }
                        ],
                        "dataReductionAlgorithm": {
                            "top": {
                                "count": 30000
                            }
                        }
                    }
                }
            }
        ],
