    "style": "style/visual.less",
    "stringResources": {
        "en-US": {
            "Visual_Short_Description": "Data table with inline sparkline trend lines for compact trend visualization.",
            "Visual_Long_Description": "A table visual that displays categories, numeric measures, text columns, and inline sparkline charts showing trends over time.",
            "Visual_Header_Trend": "Trend",
            "Visual_Empty_DropFields": "Drop a Row Category, Sparkline Category, and Measures",
            "Visual_Empty_RequiresFields": "Requires Row Category, Sparkline Category, and at least one Measure",
            "Visual_Empty_NeedMeasure": "Drop at least one Measure or Text Column"
        }
    },
    "capabilities": {
        "dataRoles": [
            {
                "displayName": "Row Category",
                "name": "rowCategory",
                "kind": "Grouping",
                "description": "What each row represents (e.g. Beat, BatteryCode)"
            },
            {
                "displayName": "Sparkline Category",
                "name": "sparklineCategory",
                "kind": "Grouping",
                "description": "Time axis for sparklines (e.g. Date)"
            },
            {
                "displayName": "Measures",
                "name": "measures",
                "kind": "Measure",
                "requiredTypes": [
                    {
                        "numeric": true
                    }
                ],
                "description": "Numeric metric columns displayed in the table."
            },
            {
                "displayName": "Text Columns",
                "name": "textColumns",
                "kind": "GroupingOrMeasure",
                "description": "Text columns displayed after numeric measures."
            },
            {
                "displayName": "Sparkline Value",
                "name": "sparklineValue",
                "kind": "Measure",
                "requiredTypes": [
                    {
                        "numeric": true
                    }
                ],
                "description": "Numeric measure for the sparkline trend chart."
            }
        ],
