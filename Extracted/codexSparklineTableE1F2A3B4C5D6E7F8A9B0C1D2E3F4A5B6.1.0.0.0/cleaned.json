        "dataViewMappings": [
            {
                "categorical": {
                    "categories": {
                        "select": [
                            {
                                "for": {
                                    "in": "rowCategory"
                                }
                            },
                            {
                                "for": {
                                    "in": "sparklineCategory"
                                }
                            },
                            {
                                "for": {
                                    "in": "textColumns"
                                }
                            }
                        ],
                        "dataReductionAlgorithm": {
                            "top": {
                                "count": 5000
                            }
                        }
                    },
                    "values": {
                        "select": [
                            {
                                "bind": {
                                    "to": "measures"
                                }
                            },
                            {
                                "bind": {
                                    "to": "textColumns"
                                }
                            },
                            {
