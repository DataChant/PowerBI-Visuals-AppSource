{
    "visual": {
        "name": "assetCard",
        "displayName": "AssetCard",
        "guid": "assetCardD5D182153530",
        "visualClassName": "Visual",
        "version": "1.0.0.3",
        "description": "Custom Cards to represent machine asset. Display asset number and value with customizable font size. Ideal for dashboards showcasing equipment status or performance metrics. Page tooltips enabled for enhanced interactivity. Right-click to drill through data.",
        "supportUrl": "https://github.com/lcse1706/PowerBI_AssetCard/issues",
        "gitHubUrl": "https://github.com/lcse1706/PowerBI_AssetCard"
    },
    "author": {
        "name": "Lukasz Czarniecki",
        "email": "lukasz.czarniecki@scania.com"
    },
    "apiVersion": "5.10.0",
    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "dataRoles": [
            {
                "displayName": "Asset Number",
                "name": "asset",
                "kind": "Grouping"
            },
            {
                "displayName": "Value",
                "name": "value",
                "kind": "Measure"
            }
        ],
        "dataViewMappings": [
            {
                "conditions": [
                    {
                        "asset": {
                            "max": 1
                        },
                        "value": {
                            "max": 1
                        }
                    }
                ],
                "categorical": {
                    "categories": {
                        "for": {
                            "in": "asset"
                        }
                    },
                    "values": {
                        "for": {
                            "in": "value"
                        }
                    }
                }
            }
        ],
        "tooltips": {
            "supportsEnhancedTooltips": true,
            "supportedTypes": {
                "default": true,
                "canvas": true
            }
        },
        "objects": {
            "assetSettings": {
                "displayName": "Asset Settings",
                "properties": {
                    "fontSize": {
                        "displayName": "Font Size",
                        "type": {
                            "numeric": true
                        }
                    },
                    "enableFiltering": {
                        "displayName": "Filter other visuals",
                        "type": {
                            "bool": true
                        }
                    }
                }
            }
        },
        "supportsHighlight": true,
        "privileges": []
    },
    "visualEntryPoint": "",
    "externalJS": [],
    "assets": {
        "icon": "assets/icon.png"
    }
}