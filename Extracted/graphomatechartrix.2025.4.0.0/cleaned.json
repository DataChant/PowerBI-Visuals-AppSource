                                {
                                    "displayName": " M I N",
                                    "value": "MIN"
                                },
                                {
                                    "displayName": " M A X",
                                    "value": "MAX"
                                },
                                {
                                    "displayName": " C U M U L A T I V E_ M E A N",
                                    "value": "CUMULATIVE_MEAN"
                                },
                                {
                                    "displayName": " G E O M E T R I C_ M E A N",
                                    "value": "GEOMETRIC_MEAN"
                                },
                                {
                                    "displayName": " C O U N T",
                                    "value": "COUNT"
                                },
                                {
                                    "displayName": " N U L L",
                                    "value": "NULL"
                                },
                                {
                                    "displayName": " N O N E",
                                    "value": "NONE"
                                }
                            ]
                        },
                        "description": "The type of aggregation that is applied to the rows"
