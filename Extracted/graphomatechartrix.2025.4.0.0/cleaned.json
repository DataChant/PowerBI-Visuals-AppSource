                        "displayName": "Category Semantics",
                        "type": {
                            "text": true
                        },
                        "description": "Assigns Semantics to specific categories"
                    }
                },
                "objectCategory": 1
            },
            "Data": {
                "displayName": "Data",
                "properties": {
                    "deviationCalculations": {
                        "displayName": "Deviations",
                        "type": {
                            "text": true
                        },
                        "description": "Adds calculated members to the data set representing absolute or percent deviations between two existing ones"
                    },
                    "customCalculations": {
                        "displayName": "Calculated Members",
                        "type": {
                            "text": true
                        },
                        "description": "Adds calculated members to the data set representing a custom calculation"
