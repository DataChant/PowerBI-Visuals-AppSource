        "dataViewMappings": [
            {
                "matrix": {
                    "rows": {
                        "for": {
                            "in": "rowCategory"
                        },
                        "dataReductionAlgorithm": {
                            "top": {
                                "count": 10000
                            }
                        }
                    },
                    "columns": {
                        "for": {
                            "in": "colCategory"
                        },
                        "dataReductionAlgorithm": {
                            "top": {
                                "count": 10000
                            }
                        }
                    },
                    "values": {
                        "select": [
                            {
                                "for": {
                                    "in": "measure"
                                }
                            }
                        ]
                    }
                }
            }
