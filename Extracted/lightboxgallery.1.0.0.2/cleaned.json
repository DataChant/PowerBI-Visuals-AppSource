{
    "visual": {
        "name": "LightboxGallery",
        "displayName": "Lightbox Gallery",
        "guid": "lightboxgallery",
        "visualClassName": "Visual",
        "version": "1.0.0.2",
        "description": "A responsive lightbox gallery that lets you view images in full screen. Features include deep zoom, pan, rotation, and keyboard navigation. Fully customizable appearance to match your report theme.",
        "supportUrl": "https://invenia.es",
        "gitHubUrl": "https://github.com/invenia/lightbox-gallery"
    },
    "author": {
        "name": "Invenia Solutions",
        "email": "info@invenia.es"
    },
    "apiVersion": "5.10.0",
    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "dataRoles": [
            {
                "displayName": "Image URL",
                "name": "Values",
                "kind": "GroupingOrMeasure",
                "description": "The URL column containing the images to display (https://...)"
            },
            {
                "displayName": "Information Fields",
                "name": "CamposInformacion",
                "kind": "GroupingOrMeasure",
                "description": "Fields to display in the footer bar (Title, Category, etc.)"
            },
            {
                "displayName": "Tooltips",
                "name": "tooltips",
                "kind": "GroupingOrMeasure",
                "description": "Additional fields to show when hovering over the button"
            }
        ],
        "dataViewMappings": [
            {
                "table": {
                    "rows": {
                        "select": [
                            {
                                "for": {
                                    "in": "Values"
                                }
                            },
                            {
                                "for": {
                                    "in": "CamposInformacion"
                                }
                            },
                            {
                                "for": {
                                    "in": "tooltips"
                                },
                                "optional": true
                            }
                        ]
                    }
                }
            }
        ],
        "objects": {
            "dataPointCard": {
                "displayName": "Gallery Button",
                "properties": {
                    "buttonText": {
                        "displayName": "Button Text",
                        "type": {
                            "text": true
                        }
                    },
                    "backgroundColor": {
                        "displayName": "Button Background",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "textColor": {
                        "displayName": "Text Color",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "fontSize": {
                        "displayName": "Font Size",
                        "type": {
                            "numeric": true
                        }
                    },
                    "fontFamily": {
                        "displayName": "Font Family",
                        "type": {
                            "text": true
                        }
                    }
                }
            },
            "modalDesign": {
                "displayName": "Modal Design",
                "properties": {
                    "photoBackgroundColor": {
                        "displayName": "Viewport Background",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "barBackgroundColor": {
                        "displayName": "Sidebar Background",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    },
                    "arrowBackgroundColor": {
                        "displayName": "Icons Color",
                        "description": "Color for navigation arrows, zoom, and close buttons",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    }
                }
            }
        },
        "privileges": [
            {
                "name": "WebAccess",
                "essential": true,
                "parameters": [
                    "https://*",
                    "http://*"
                ]
            }
        ],
        "supportsHighlight": true,
        "supportsMultiVisualSelection": true,
        "supportsLandingPage": true,
        "sorting": {
            "default": {}
        }
    },
    "dependencies": {},
    "visualEntryPoint": "",
    "externalJS": [],
    "assets": {
        "icon": "assets/icon.png"
    }
}