{
    "visual": {
        "name": "planogramViewer",
        "displayName": "Planogram Viewer",
        "guid": "planogramviewer_v2",
        "visualClassName": "Visual",
        "version": "1.0.0.1",
        "description": "Visualize retail planograms and Share of Shelf with interactive overlays, zoom, and product details.",
        "supportUrl": "https://invenia.es",
        "gitHubUrl": ""
    },
    "author": {
        "name": "Invenia Solutions",
        "email": "info@invenia.es"
    },
    "apiVersion": "5.10.0",
    "style": "style/visual.less",
    "stringResources": {},
    "capabilities": {
        "dataRoles": [
            {
                "displayName": "Image URL",
                "name": "imageUrl",
                "kind": "Grouping"
            },
            {
                "displayName": "Id",
                "name": "boxId",
                "kind": "Grouping"
            },
            {
                "displayName": "Tooltip Fields",
                "name": "tooltips",
                "kind": "GroupingOrMeasure"
            },
            {
                "displayName": "X Coordinate",
                "name": "boxX",
                "kind": "Measure"
            },
            {
                "displayName": "Y Coordinate",
                "name": "boxY",
                "kind": "Measure"
            },
            {
                "displayName": "Width",
                "name": "boxW",
                "kind": "Measure"
            },
            {
                "displayName": "Height",
                "name": "boxH",
                "kind": "Measure"
            },
            {
                "displayName": "Color (Hex)",
                "name": "boxColor",
                "kind": "GroupingOrMeasure"
            }
        ],
        "objects": {
            "boxStyles": {
                "displayName": "Box Styles",
                "properties": {
                    "strokeWidth": {
                        "displayName": "Stroke Width",
                        "type": {
                            "numeric": true
                        }
                    },
                    "fillOpacity": {
                        "displayName": "Fill Opacity (%)",
                        "type": {
                            "numeric": true
                        }
                    },
                    "defaultColor": {
                        "displayName": "Default Color",
                        "type": {
                            "fill": {
                                "solid": {
                                    "color": true
                                }
                            }
                        }
                    }
                }
            },
            "messageStyles": {
                "displayName": "Messages & Text",
                "properties": {
                    "loadingText": {
                        "displayName": "Loading Text",
                        "type": {
                            "text": true
                        }
                    },
                    "errorText": {
                        "displayName": "Error Text",
                        "type": {
                            "text": true
                        }
                    },
                    "noDataText": {
                        "displayName": "No Data Text",
                        "type": {
                            "text": true
                        }
                    }
                }
            }
        },
        "dataViewMappings": [
            {
                "table": {
                    "rows": {
                        "select": [
                            {
                                "for": {
                                    "in": "imageUrl"
                                }
                            },
                            {
                                "for": {
                                    "in": "boxId"
                                }
                            },
                            {
                                "for": {
                                    "in": "tooltips"
                                }
                            },
                            {
                                "for": {
                                    "in": "boxX"
                                }
                            },
                            {
                                "for": {
                                    "in": "boxY"
                                }
                            },
                            {
                                "for": {
                                    "in": "boxW"
                                }
                            },
                            {
                                "for": {
                                    "in": "boxH"
                                }
                            },
                            {
                                "for": {
                                    "in": "boxColor"
                                }
                            }
                        ]
                    }
                }
            }
        ],
        "privileges": [
            {
                "name": "WebAccess",
                "essential": true,
                "parameters": [
                    "https://*"
                ]
            }
        ]
    },
    "visualEntryPoint": "",
    "externalJS": [],
    "assets": {
        "icon": "assets/icon.png"
    }
}